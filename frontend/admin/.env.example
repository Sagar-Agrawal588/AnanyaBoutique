# ============================================
# ADMIN FRONTEND - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.local and fill in values
# Never commit .env.local - it contains secrets!

# Backend API URL
NEXT_PUBLIC_API_URL=https://healthy-one-gram.el.r.appspot.com
# Optional local backend URL override for faster local admin development.
# Example: NEXT_PUBLIC_LOCAL_API_URL=http://127.0.0.1:8001
# NEXT_PUBLIC_LOCAL_API_URL=

# Optional public storefront/client URL used when Admin copies influencer
# referral links and collaborator login links.
# Local fallback is automatic when Admin runs on localhost:3001.
# Example production: NEXT_PUBLIC_SITE_URL=https://healthyonegram.com
# Example local: NEXT_PUBLIC_CLIENT_URL=http://localhost:3000
# NEXT_PUBLIC_CLIENT_URL=
# NEXT_PUBLIC_SITE_URL=https://healthyonegram.com

# Optional: Share base URL for Partner API guide links shown in Admin -> API PDFs.
# Example (recommended on local Admin when you want to share live docs):
# NEXT_PUBLIC_SHARE_BASE_URL=https://healthyonegram.com

# Firebase Configuration (for Google OAuth)
# Get from: https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
# Optional analytics key
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
