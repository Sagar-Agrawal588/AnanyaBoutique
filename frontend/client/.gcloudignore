# Prevent the ignore file from being uploaded as part of the build context.
.gcloudignore

# Exclude repository metadata from App Engine uploads.
.git
.gitignore

# Let Cloud Build install fresh dependencies from package-lock.json.
node_modules/

# Skip local Next.js build output and caches; App Engine rebuilds during deploy.
.next/

# Do not upload local environment files; build-time variables come from app.yaml.
.env
.env.*
!.env.example

# Exclude local test suites, snapshots, and Playwright output from production deploys.
tests/
test-results/

# Skip build logs and other local debug artifacts.
build_log*.txt
coverage/
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Exclude local temp files and editor metadata.
tmp/
.cache/
*.tsbuildinfo
.DS_Store
Thumbs.db
.vscode/
