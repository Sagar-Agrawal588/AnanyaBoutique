# ============================================
# ANANYA BOUTIQUE - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in actual values
# Never commit .env file - it contains secrets!

# ============================================
# SERVER CONFIGURATION
# ============================================
# Local development port. Cloud Run injects PORT=8080 automatically; do not
# set PORT in Cloud Run service environment variables.
PORT=8000
# Public backend domain used in partner docs and links
# BASE_URL=https://api.ananyaboutique.com
NODE_ENV=development
# Optional Excel templates for admin exports
# ORDER_REPORT_TEMPLATE_PATH=path/to/your/order-report-template.xlsx
# PRICING_ENGINE_TEMPLATE_PATH=path/to/your/pricing-engine-template.xlsx
# Pricing Engine defaults (used when exporting the Pricing Engine sheet)
# PRICING_ENGINE_DEFAULT_DELIVERY_COST=80
# PRICING_ENGINE_DEFAULT_CGST_PERCENT=2.5
# PRICING_ENGINE_DEFAULT_SGST_PERCENT=2.5
# PRICING_ENGINE_DEFAULT_TARGET_MARGIN_PERCENT=0
# PRICING_ENGINE_DEFAULT_INFLUENCER_COMMISSION_PERCENT=0
# PRICING_ENGINE_DEFAULT_INFLUENCER_CUSTOMER_DISCOUNT_PERCENT=0
# PRICING_ENGINE_DEFAULT_COUPON_DISCOUNT_PERCENT=0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Get this from: https://www.mongodb.com/cloud/atlas
# Use a non-secret placeholder here so secret scanners do not flag the example.
# Cloud Run must set MONGO_URI. MONGODB_URI is accepted by the app only as a fallback.
MONGO_URI=YOUR_MONGODB_URI_HERE

# ============================================
# AUTHENTICATION (JWT)
# ============================================
# Generate random 32+ character strings for each
# Option: Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars_long
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars_long
# Primary admin email allowed to access /admin
ADMIN_PRIMARY_EMAIL=admin@ananyaboutique.com
# Optional manager email allowed to access /admin
MANAGER_PRIMARY_EMAIL=manager@ananyaboutique.com
# Optional comma-separated default permission keys applied to manager account setup.
# Allowed keys: manage_users, view_analytics, manage_crm, manage_membership, manage_shipping, manage_settings
# MANAGER_DEFAULT_PERMISSIONS=view_analytics,manage_crm
# Privileged account bootstrap passwords (used by seeder/ensurePrivilegedUsers script)
# ADMIN_PRIMARY_PASSWORD=<set-in-github-secret>
# MANAGER_PRIMARY_PASSWORD=<set-in-github-secret>
# Optional comma-separated allowlist for admin panel login emails.
# ADMIN_ALLOWED_EMAILS=admin@ananyaboutique.com,manager@ananyaboutique.com
# Optional legacy keys (for migration only):
# SECRET_KEY_ACCESS_TOKEN=your_access_token_secret_min_32_chars_long
# SECRET_KEY_REFRESH_TOKEN=your_refresh_token_secret_min_32_chars_long
# JSON_WEB_TOKEN_SECRET_KEY=your_jwt_secret_min_32_chars_long
# JWT_SECRET=your_jwt_secret_min_32_chars_long
# Optional Pay-Now email token signing (defaults to ACCESS_TOKEN_SECRET)
# PAY_ORDER_TOKEN_SECRET=your_pay_order_token_secret_min_32_chars_long
# PAY_ORDER_TOKEN_TTL_DAYS=7

# ============================================
# EMAIL SERVICE (Gmail with App Password)
# ============================================
# 1. Enable 2FA on Gmail: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the generated password here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<set-in-github-secret>
SMTP_PASS=<set-in-github-secret>
EMAIL_FROM_NAME=Ananya Boutique
EMAIL_FROM_ADDRESS=<set-in-github-secret>
# Optional compatibility fallback (legacy keys still supported)
# EMAIL=<set-in-github-secret>
# EMAIL_PASSWORD=<set-in-github-secret>
# Optional retry tuning
# EMAIL_RETRY_COUNT=2
# EMAIL_RETRY_DELAY_MS=700

# ============================================
# CLOUDINARY (Image/File Storage)
# ============================================
# Sign up: https://cloudinary.com/console
# Get credentials from: https://cloudinary.com/console/settings/credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key_number
CLOUDINARY_API_SECRET=your_api_secret_string

# MEDIA STORAGE
# Default is Firebase Storage / GCS. Set MEDIA_STORAGE_PROVIDER=cloudinary only
# if you want to keep using Cloudinary for new uploads.
# In most setups no extra backend-only storage config is needed because the
# backend can infer the bucket from NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET or
# FIREBASE_PROJECT_ID. Add FIREBASE_STORAGE_BUCKET only if your bucket differs.
MEDIA_STORAGE_PROVIDER=firebase
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# GCS_MEDIA_BUCKET=your-public-media-bucket
# GCS_MEDIA_PUBLIC_BASE_URL=https://storage.googleapis.com/your-public-media-bucket
# GCS_MEDIA_MAKE_PUBLIC=false

# ============================================
# PAYTM PAYMENT GATEWAY
# ============================================
# Merchant portal: https://business.paytm.com
# Integration docs: https://business.paytm.com/docs
#
# STATUS: Set to 'true' only when credentials are configured
PAYTM_ENABLED=false

# Paytm Merchant Credentials
# PAYTM_MERCHANT_ID=your_mid
# PAYTM_MERCHANT_KEY=your_merchant_key
# PAYTM_ENV=UAT  # or PROD for production
# PAYTM_WEBSITE=WEBSTAGING
# PAYTM_CHANNEL_ID_WEB=WEB
# PAYTM_BASE_URL=https://securestage.paytmpayments.com
# Optional order callback override (default: /api/orders/webhook/paytm)
# PAYTM_ORDER_CALLBACK_URL=https://api.ananyaboutique.com/api/orders/webhook/paytm
# Optional membership callback override (default: /membership/checkout)
# PAYTM_MEMBERSHIP_CALLBACK_URL=https://ananyaboutique.com/membership/checkout

# ============================================
# PHONEPE PAYMENT GATEWAY (OPTIONAL / DUAL-PROVIDER)
# ============================================
# PHONEPE_ENABLED=false
# PHONEPE_CLIENT_ID=your_phonepe_client_id
# PHONEPE_CLIENT_SECRET=your_phonepe_client_secret
# PHONEPE_CLIENT_VERSION=1
# PHONEPE_ENV=PROD  # PROD or UAT
# PHONEPE_BASE_URL=https://api.phonepe.com/apis
# Optional checkout callbacks
# PHONEPE_ORDER_CALLBACK_URL=https://api.ananyaboutique.com/api/orders/webhook/phonepe
# PHONEPE_REDIRECT_URL=https://ananyaboutique.com/payment/phonepe

# Backend public URL (used for callbacks)
# BACKEND_URL=https://api.ananyaboutique.com

# ============================================
# XPRESSBEES SHIPPING
# ============================================
# Option 1: Static token (recommended)
# XPRESSBEES_TOKEN=your_xpressbees_bearer_token
#
# Option 2: Login with email/password (token cached server-side)
# XPRESSBEES_EMAIL=your_login_email
# XPRESSBEES_PASSWORD=your_login_password
#
# Optional overrides
# XPRESSBEES_BASE_URL=https://shipment.xpressbees.com/api
# XPRESSBEES_TOKEN_TTL_MINUTES=720
# XPRESSBEES_ORDER_PREFIX=ANB
# XPRESSBEES_PACKAGE_WEIGHT_UNIT=g
# Webhook verification (optional but recommended)
# XPRESSBEES_WEBHOOK_SECRET=your_webhook_secret
# Polling fallback (used when webhook delivery is unavailable)
# In production, polling auto-starts when Xpressbees credentials are configured.
# Set XPRESSBEES_POLL_ENABLED=false only if carrier polling must be disabled.
# XPRESSBEES_POLL_ENABLED=true
# XPRESSBEES_POLL_INTERVAL_MINUTES=5
# XPRESSBEES_POLL_BATCH_SIZE=50
# Origin pincode for rate quote requests
# SHIPPER_PINCODE=302019
# XPRESSBEES_ORIGIN_PINCODE=302019

# ============================================
# INVENTORY RESERVATION EXPIRY
# ============================================
# Auto-release unpaid reservations after TTL
# INVENTORY_RESERVATION_ENABLED=false
# INVENTORY_RESERVATION_MINUTES=30
# INVENTORY_RESERVATION_INTERVAL_MINUTES=5
# INVENTORY_RESERVATION_BATCH_SIZE=50

# ============================================
# BACKGROUND JOB COORDINATION
# ============================================
# Prevents autoscaled backend instances from all running the same timers.
# Disable only if you intentionally want every instance to run background work.
# BACKGROUND_JOB_LOCKS_ENABLED=true
# Optional explicit owner label for debugging lease ownership
# BACKGROUND_JOB_OWNER_ID=backend-primary

# ============================================
# INVOICE SETTINGS
# ============================================
# Seller/company details printed on invoice PDFs
# INVOICE_SELLER_NAME=Ananya Boutique
# INVOICE_SELLER_GSTIN=08XXXXXXXXXXXX
# INVOICE_SELLER_ADDRESS=G-222, RIICO, Sitapura, Jaipur, Rajasthan
# INVOICE_SELLER_STATE=Rajasthan
# INVOICE_SELLER_STATE_CODE=08
# INVOICE_SELLER_CIN=U51909RJ2020PTC071817
# INVOICE_SELLER_MSME=UDYAM-RJ-17-0154669
# INVOICE_SELLER_FSSAI=12224027000921
# INVOICE_SELLER_PHONE=+91XXXXXXXXXX
# INVOICE_SELLER_EMAIL=support@ananyaboutique.com
# INVOICE_CURRENCY_SYMBOL=Rs.
# INVOICE_DEFAULT_HSN=2106
# INVOICE_DEFAULT_GST_RATE=5

# ============================================
# Frontend URLs (CORS Configuration)
# ============================================
SITE_URL=https://ananyaboutique.com
CLIENT_URL=https://ananyaboutique.com
ADMIN_URL=https://admin.ananyaboutique.com
# Optional comma-separated list for additional trusted origins
# Include the Vercel storefront while the custom domain is being connected.
# CORS_ORIGINS=https://ananyaboutique.com,https://www.ananyaboutique.com,https://ananya-boutique-client.vercel.app,https://admin.ananyaboutique.com

# Redis connection (recommended for production partner rate limiting)
# REDIS_URL=redis://default:password@host:6379

# Optional cookie domain (production only)
# Example: COOKIE_DOMAIN=.ananyaboutique.com
# COOKIE_DOMAIN=

# ============================================
# WHATSAPP BUSINESS / META WEBHOOKS
# ============================================
# Required for Meta webhook verification
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
# Strongly recommended for webhook signature verification
# WHATSAPP_APP_SECRET=your_meta_app_secret
# Optional future outbound-send config
# WHATSAPP_ACCESS_TOKEN=your_meta_permanent_access_token
# WHATSAPP_APP_ID=your_meta_app_id
# WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_meta_business_account_id
# WHATSAPP_GRAPH_API_VERSION=v25.0
# Template language codes must match the approved Meta template exactly, e.g. en_US.

# ============================================
# EVENT-DRIVEN ANALYTICS TRACKING
# ============================================
# Enable/disable Pub/Sub publishing from backend tracking endpoint
ANALYTICS_PUBSUB_ENABLED=true
# Pub/Sub topic for user activity events
ANALYTICS_PUBSUB_TOPIC=user-behavior-events
# Pub/Sub subscription consumed by analytics worker
ANALYTICS_PUBSUB_SUBSCRIPTION=user-behavior-events-sub
# Dead-letter topic for failed analytics messages
ANALYTICS_PUBSUB_DEAD_LETTER_TOPIC=user-behavior-events-dead-letter
# Retry attempts for publish failures
# ANALYTICS_PUBLISH_MAX_ATTEMPTS=3
# Pub/Sub publisher batching settings
# ANALYTICS_PUBLISH_BATCH_MESSAGES=50
# ANALYTICS_PUBLISH_BATCH_MS=10
# HttpOnly cookie name for analytics session tracking
ANALYTICS_SESSION_COOKIE=hog_sid
# Optional analytics consent cookie name
# ANALYTICS_CONSENT_COOKIE=analytics_consent
# Optional dedicated analytics database URI (falls back to MONGO_URI if omitted)
# ANALYTICS_MONGO_URI=YOUR_ANALYTICS_MONGODB_URI_HERE
# Optional dedicated analytics database/schema name
ANALYTICS_DB_NAME=analytics
# Optional analytics DB connection pool settings
# ANALYTICS_DB_MAX_POOL_SIZE=20
# ANALYTICS_DB_MIN_POOL_SIZE=2
# Optional tracking payload limits
# TRACKING_BATCH_MAX_EVENTS=500
# TRACKING_BATCH_MAX_BYTES=262144
# Optional IP anonymization for privacy compliance
# ANALYTICS_MASK_IP=true
# Respect browser Do Not Track / Global Privacy Control headers.
# Defaults to false in development and true in production when unset.
# ANALYTICS_RESPECT_DNT=true
# Optional Google Cloud project id for Pub/Sub
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional smoke-test API base URL (defaults to http://localhost:${PORT})
# TRACKING_TEST_API_URL=http://localhost:8000
# Optional smoke test worker controls
# TRACKING_TEST_START_WORKER=true
# TRACKING_TEST_HTTP_TIMEOUT_MS=12000
# TRACKING_TEST_WORKER_BOOT_TIMEOUT_MS=20000
# Optional explicit service account bindings for setup/provisioning scripts
# ANALYTICS_BACKEND_SERVICE_ACCOUNT_EMAIL=backend-sa@your-gcp-project-id.iam.gserviceaccount.com
# ANALYTICS_WORKER_SERVICE_ACCOUNT_EMAIL=analytics-worker-sa@your-gcp-project-id.iam.gserviceaccount.com

# Backend public URL (used for payment/membership callback fallback)
# BACKEND_URL=https://api.ananyaboutique.com

# ============================================
# OPTIONAL: Logging & Monitoring
# ============================================
# LOG_LEVEL=info
# SENTRY_DSN=https://xxxxxxx@xxxxxxx.ingest.sentry.io/123456
# STRIPE_KEY=sk_test_xxxxx  (if using Stripe instead)

# ============================================
# OPTIONAL: RATE LIMIT TUNING
# ============================================
# Defaults are currently set to 2500 requests per minute for all limiters.
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_DEFAULT_MAX=2500
# RATE_LIMIT_GENERAL_MAX=2500
# RATE_LIMIT_ADMIN_MAX=2500
# RATE_LIMIT_AUTH_MAX=2500
# RATE_LIMIT_PAYMENT_MAX=2500
# RATE_LIMIT_UPLOAD_MAX=2500
# RATE_LIMIT_SUPPORT_MAX=2500

# ============================================
# OPTIONAL: SAFE PERFORMANCE LAYER FLAGS
# ============================================
# Public GET rate limiter (monitor-safe high default)
# PERF_PUBLIC_GET_LIMITER_ENABLED=true
# PERF_PUBLIC_GET_LIMITER_WINDOW_SECONDS=60
# PERF_PUBLIC_GET_LIMITER_MAX=300

# Bot protection (monitor mode by default)
# PERF_BOT_PROTECTION_ENABLED=true
# PERF_BOT_PROTECTION_MONITOR_ONLY=true
# PERF_BOT_PROTECTION_BLOCK_ENABLED=false
# PERF_BOT_PROTECTION_LOG_WINDOW_MS=60000

# Public cache headers (applies only to banners/home-slides/maintenance-status)
# PERF_HTTP_CACHE_HEADERS_ENABLED=true
# PERF_CACHE_BANNERS_TTL_SECONDS=60
# PERF_CACHE_HOME_SLIDES_TTL_SECONDS=60
# PERF_CACHE_MAINTENANCE_STATUS_TTL_SECONDS=30

# Redis-backed server response cache for anonymous public GET endpoints
# Falls back to process memory when Redis is unavailable.
# PERF_RESPONSE_CACHE_ENABLED=true
# PERF_RESPONSE_CACHE_KEY_PREFIX=public-response-cache
# PERF_RESPONSE_CACHE_PRODUCTS_TTL_SECONDS=45
# PERF_RESPONSE_CACHE_CATEGORIES_TTL_SECONDS=300
# PERF_RESPONSE_CACHE_SETTINGS_TTL_SECONDS=90
# PERF_RESPONSE_CACHE_MAINTENANCE_STATUS_TTL_SECONDS=30
# PERF_RESPONSE_CACHE_COMBOS_TTL_SECONDS=60
# PERF_RESPONSE_CACHE_BANNERS_TTL_SECONDS=120
# PERF_RESPONSE_CACHE_HOME_SLIDES_TTL_SECONDS=120
# PERF_RESPONSE_CACHE_CONTENT_TTL_SECONDS=180

# Compression safety controls
# PERF_COMPRESSION_ENABLED=true
# PERF_COMPRESSION_THRESHOLD_BYTES=1024

# Slow request monitor (logging only)
# PERF_SLOW_REQUEST_LOGGER_ENABLED=true
# PERF_SLOW_REQUEST_MS=500

# Skip heavy middleware for health/public GET endpoints only
# PERF_MIDDLEWARE_BYPASS_ENABLED=true

# Socket transport rollout controls (polling kept enabled by default)
# PERF_SOCKET_TRANSPORT_LOG_ENABLED=true
# PERF_SOCKET_PREFER_WEBSOCKET=false
# PERF_SOCKET_ALLOW_POLLING=true

# ============================================
# OPTIONAL: PUBLIC CONTENT RESPONSE CACHING
# ============================================
# In-memory cache TTL for public /api/banners response payloads (milliseconds)
# BANNERS_PUBLIC_CACHE_TTL_MS=120000
# In-memory cache TTL for public /api/home-slides response payloads (milliseconds)
# HOME_SLIDES_PUBLIC_CACHE_TTL_MS=120000

# ============================================
# FIREBASE ADMIN SDK (Push Notifications)
# ============================================
# 1. Go to Firebase Console: https://console.firebase.google.com
# 2. Project Settings > Service Accounts
# 3. Generate new private key
# 4. Copy values from the downloaded JSON
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
# Current live catalog reads stay on MongoDB while product media is stored in Firebase Storage.
# Set true only after the Firestore catalog is fully migrated and verified.
FIREBASE_CATALOG_PRIMARY=false
# Production ignores FIREBASE_CATALOG_PRIMARY unless this explicit override is true.
FIREBASE_CATALOG_PRIMARY_ALLOW_PRODUCTION=false
# Order mirror writes can be disabled if you no longer need Firestore-based realtime order updates.
# ORDER_FIRESTORE_SYNC_ENABLED=true
# Identical order payloads are skipped for this cache window to reduce write volume.
# ORDER_FIRESTORE_SYNC_CACHE_TTL_MS=300000

# ============================================
# INFLUENCER PORTAL AUTH (Collaborator Login)
# ============================================
# Used to sign collaborator portal tokens
# If omitted, ACCESS_TOKEN_SECRET (or legacy JWT keys) is used as fallback
INFLUENCER_JWT_SECRET=your_influencer_jwt_secret
# Used to sign refresh tokens (optional)
# If omitted, INFLUENCER_JWT_SECRET or REFRESH_TOKEN_SECRET is used as fallback
INFLUENCER_REFRESH_TOKEN_SECRET=your_influencer_refresh_secret

# ============================================
# NOTES
# ============================================
# 1. Never commit .env - add it to .gitignore
# 2. In production, use strong random strings (32+ chars)
# 3. Rotate secrets regularly
# 4. Keep backups of working .env files
# 5. Use .env.example for documentation (no secrets)
# 6. Test all credentials after setting up
