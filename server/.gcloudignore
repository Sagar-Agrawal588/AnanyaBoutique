# Prevent the ignore file from being uploaded as part of the build context.
.gcloudignore

# Exclude repository metadata from App Engine uploads.
.git
.gitignore

# Let Cloud Build install fresh dependencies from package-lock.json.
node_modules/

# Skip local environment files; App Engine runtime settings come from app.yaml.
.env
.env.*
!.env.example

# Do not upload local test code or API collection assets to production.
tests/
postman/

# Skip one-off scripts and temporary debugging artifacts.
tmp/

# Exclude locally generated uploads; production should use persistent object storage.
uploads/

# Keep generated invoices out of deploys because they are runtime artifacts, not source.
invoices/

# Avoid uploading local logs and coverage output.
coverage/
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Exclude local build caches and TypeScript metadata.
.cache/
*.tsbuildinfo

# Skip editor and OS cruft.
.DS_Store
Thumbs.db
.vscode/
