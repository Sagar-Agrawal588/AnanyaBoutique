    {
      "name": "04 Rate Limit Validation",
      "item": [
        {
          "name": "Rate Limit Init",
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.environment.set('rl_iteration', '0');",
            "pm.environment.set('rl_429_seen', '0');",
            "pm.test('Init status 200', function(){ pm.response.to.have.status(200); });"
          ]}}],
          "request": {"method":"GET","header":[{"key":"x-api-key","value":"{{api_key}}"}],"url":{"raw":"{{base_url}}/api/v1/partner/health","host":["{{base_url}}"],"path":["api","v1","partner","health"]}}
        },
        {
          "name": "Low Key Burst",
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "let i = Number(pm.environment.get('rl_iteration') || '0') + 1;",
            "pm.environment.set('rl_iteration', String(i));",
            "pm.test('Status is 200 or 429', function(){ pm.expect([200,429]).to.include(pm.response.code); });",
            "if (pm.response.code === 429) pm.environment.set('rl_429_seen', '1');",
            "if (i < 25) {",
            "  postman.setNextRequest('Low Key Burst');",
            "} else {",
            "  postman.setNextRequest('Rate Limit Assert');",
            "}"
          ]}}],
          "request": {"method":"GET","header":[{"key":"x-api-key","value":"{{low_api_key}}"}],"url":{"raw":"{{base_url}}/api/v1/partner/health","host":["{{base_url}}"],"path":["api","v1","partner","health"]}}
        },
        {
          "name": "Rate Limit Assert",
          "event": [{"listen":"test","script":{"type":"text/javascript","exec":[
            "pm.test('Medium key stays healthy', function(){ pm.response.to.have.status(200); });",
            "pm.test('429 observed on low key', function(){ pm.expect(pm.environment.get('rl_429_seen')).to.eql('1'); });"
          ]}}],
          "request": {"method":"GET","header":[{"key":"x-api-key","value":"{{api_key}}"}],"url":{"raw":"{{base_url}}/api/v1/partner/health","host":["{{base_url}}"],"path":["api","v1","partner","health"]}}
        }
      ]
